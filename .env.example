VITE_API_BASE_URL=https://travel-system-sigma.vercel.app
VITE_API_KEY=replace_with_production_api_key

# Engineering requests are sent to:
# ${VITE_API_BASE_URL}/api/v1/public/engineering-requests
# During local TRINSU testing use:
# VITE_API_BASE_URL=http://localhost:3000
# VITE_API_KEY must match MOTOR_API_KEY in the TRINSU .env file.
